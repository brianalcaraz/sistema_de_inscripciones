extends ../layout

block contenido
  .row.justify-content-center
    .col-md-6
      h2.mb-4 Modificar Administrativo
      
      form.card.p-4.shadow-sm(action=`/api/administrativos/editar/${admin.id}` method="POST")
        .mb-3
          label.fw-bold Nombre:
          input.form-control(type="text" name="name" value=admin.name required)
        .mb-3
          label.fw-bold Email:
          input.form-control(type="email" name="email" value=admin.email required)
        .mb-3
          label.fw-bold Nueva Contraseña:
          input.form-control(type="password" name="password" value=admin.password required)
        .mb-3
          label.fw-bold Rol:
          input.form-control(type="text" name="rol" value=admin.rol required)
        .mb-3
          label.fw-bold Área:
          input.form-control(type="text" name="area" value=admin.area required)
        
        button.btn.btn-primary(type="submit") Actualizar Datos
        a.btn.btn-secondary.ms-2(href="/api/administrativos") Cancelar